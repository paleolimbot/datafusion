LIBDIR = datafusion-c/target/release
STATLIB = $(LIBDIR)/libdatafusion.a
PKG_CFLAGS = -pthread
PKG_LIBS = -L$(LIBDIR) -ldatafusion -lresolv -pthread

#all: clean

$(SHLIB): $(STATLIB)

# CRAN policy forbids using $HOME so we build in the current working dir.
# This makes things really slow because we have to reinstall all dependencies
# for each build. Comment this out for non-CRAN releases.
# CARGOTMP=$(PWD)/.cargo
# export CARGO_HOME=$(CARGOTMP)

$(STATLIB):
	PATH="${PATH}:${HOME}/.cargo/bin" cargo build --release --manifest-path=datafusion-c/Cargo.toml
	# rm -Rf $(CARGOTMP) || true #CRAN wants us to remove "detritus"
	rm -Rf $(LIBDIR)/build || true

clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS) datafusion-c/target
